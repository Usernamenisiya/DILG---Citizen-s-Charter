{
  "name": "dilg-kiosk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:dist": "npm run electron:build"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^0.523.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^36.3.2",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.5"
  },
  "description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Usernamenisiya/DILG---Citizen-s-Charter.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Usernamenisiya/DILG---Citizen-s-Charter/issues"
  },
  "homepage": "https://github.com/Usernamenisiya/DILG---Citizen-s-Charter#readme",
  "build": {
    "appId": "ph.dilg.caraga.kiosk",
    "productName": "DILG Citizen Charter Kiosk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "my-custom-backend",
        "to": "my-custom-backend"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/DILG-LOGO.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
